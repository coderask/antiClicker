# AntiClicker — local environment overrides
# Copy this file to .env.local (which is gitignored) and fill in values.
# This file is safe to commit — it contains no secrets.

# Optional: Google Maps JavaScript API key for high-zoom satellite imagery.
# Without this key, AntiClicker uses Esri World Imagery (free, lower zoom).
# To obtain a key: see README.md "Optional: enable Google Maps satellite".
GOOGLE_MAPS_API_KEY=
